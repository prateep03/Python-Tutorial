{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/validate-lesson.sh",
            "statusMessage": "Validating lesson structure...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
